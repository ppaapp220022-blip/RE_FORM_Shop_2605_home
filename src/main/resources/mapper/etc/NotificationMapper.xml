<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.re_form_shop_2605.mapper.etc.NotificationMapper">
    <!--    // 특정 회원의 전체 알림 목록 조회-->
    <select id="findNotificationsByMemberId" parameterType="java.lang.Long" resultType="com.re_form_shop_2605.domain.etc.NotificationVO">
        SELECT * FROM notification WHERE member_id = #{memberId} ORDER BY noti_id DESC
    </select>

    <!--    // 읽음 여부 수정-->
    <update id="updateReadStatus">
        UPDATE notification SET is_read = #{isRead} WHERE noti_id = #{notiId}
    </update>

    <!--    // 알림 번호로 삭제-->
    <delete id="deleteNotification" parameterType="java.lang.Long">
        DELETE FROM notification WHERE noti_id = #{notiId}
    </delete>

</mapper>
