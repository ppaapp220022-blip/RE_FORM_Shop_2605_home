<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.re_form_shop_2605.mapper.member.InterestKeywordMapper">
<!--    관심 키워드 등록-->
    <insert id="insertInterestKeyword" parameterType="com.re_form_shop_2605.domain.member.InterestKeywordVO"
            useGeneratedKeys="true" keyProperty="keywordId" keyColumn="keyword_id">
        INSERT INTO interest_keyword (member_id, keyword)
        VALUES (#{memberId}, #{keyword})
    </insert>

<!--    관심 키워드 목록 조회-->
    <select id="findInterestKeywordsByMemberId" parameterType="java.lang.Long" resultType="com.re_form_shop_2605.domain.member.InterestKeywordVO">
            SELECT * FROM interest_keyword WHERE member_id = #{memberId} ORDER BY keyword_id ASC
    </select>

<!--    회원의 모든 관심 키워드 삭제-->
    <delete id="deleteInterestKeywordsByMemberId" parameterType="java.lang.Long">
            DELETE FROM interest_keyword WHERE member_id = #{memberId}
    </delete>
</mapper>
