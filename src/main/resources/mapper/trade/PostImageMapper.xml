<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.re_form_shop_2605.mapper.trade.PostImageMapper">
    <!--    // 게시글 이미지 등록-->
    <insert id="insertPostImage" parameterType="com.re_form_shop_2605.domain.trade.PostImageVO"
            useGeneratedKeys="true" keyProperty="imageId" keyColumn="image_id">
            INSERT INTO post_image (post_id, image_url, sort_order)
            VALUES (#{postId}, #{imageUrl}, #{sortOrder})
    </insert>

    <!--    // 게시글 번호로 이미지 목록 조회-->
    <select id="findPostImagesByPostId" parameterType="java.lang.Long" resultType="com.re_form_shop_2605.domain.trade.PostImageVO">
            SELECT * FROM post_image WHERE post_id = #{postId} ORDER BY sort_order ASC
    </select>

    <!--    // 특정 게시글의 전체 이미지 삭제-->
    <delete id="deletePostImagesByPostId" parameterType="java.lang.Long">
            DELETE FROM post_image WHERE post_id = #{postId}
    </delete>
</mapper>
