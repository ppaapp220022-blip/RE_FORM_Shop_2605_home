<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.re_form_shop_2605.mapper.chat.ChatMessageMapper">
    <resultMap id="chatMessageResultMap" type="com.re_form_shop_2605.domain.chat.ChatMessageVO">
        <id property="messageId" column="message_id"/>
        <result property="senderId" column="sender_id"/>
        <result property="content" column="content"/>
        <result property="type" column="type"/>
        <result property="createdAt" column="created_at"/>
        <result property="isRead" column="is_read"/>
        <association property="riskAnalysisResultVO" javaType="com.re_form_shop_2605.domain.etc.RiskAnalysisResultVO" columnPrefix="r_">
            <id property="riskId" column="risk_id"/>
            <result property="riskLevel" column="risk_level"/>
            <result property="reason" column="reason"/>
            <result property="suggestion" column="suggestion"/>
        </association>
    </resultMap>
    <select id="findMessagesWithModeration" resultMap="chatMessageResultMap">
        SELECT
            m.message_id,
            m.sender_id,
            m.content,
            m.type,
            m.created_at,
            m.is_read,
            r.risk_id      AS r_risk_id,
            r.risk_level   AS r_risk_level,
            r.reason       AS r_reason,
            r.suggestion   AS r_suggestion
        FROM chat_message m
                 LEFT JOIN risk_analysis_result r
                           ON  r.target_type = 'CHAT'
                               AND r.target_id   = m.message_id
        WHERE m.chat_id = #{chatId}
        ORDER BY m.created_at DESC
            LIMIT  #{size}
        OFFSET #{offset}
    </select>
    <select id="countMessagesByChatId" resultType="java.lang.Integer">
        SELECT COUNT(*) FROM chat_message WHERE chat_id = #{chatId}
    </select>
</mapper>